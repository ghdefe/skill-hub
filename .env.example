# GitHub OAuth2 (required)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# JWT signing key (required, at least 256 bits / 32 chars)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# GitHub webhook secret (required if using webhooks)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Encryption key for storing GitHub access tokens (exactly 32 bytes)
ENCRYPTION_SECRET_KEY=your-encryption-key-exactly-32b!

# Database (defaults work with docker-compose)
DATABASE_URL=jdbc:postgresql://localhost:5432/skills_sharing
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Frontend URL (for CORS / OAuth redirect)
FRONTEND_URL=http://localhost
